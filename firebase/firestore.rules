rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocExists() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDocExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return userDocExists() && userRole() == "admin";
    }

    function isComercialUp() {
      return userDocExists()
        && (userRole() == "admin" || userRole() == "comercial");
    }

    function isStaff() {
      return userDocExists()
        && (userRole() == "admin"
            || userRole() == "comercial"
            || userRole() == "tecnico");
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
      allow write: if isAdmin();
    }

    match /clientes/{docId} {
      allow read, write: if isComercialUp();
    }

    match /cotizaciones/{docId} {
      allow get: if true;
      allow list: if isComercialUp();
      allow create, delete: if isComercialUp();
      // Vista pública (public/cotizacion.html) actualiza estado al confirmar
      allow update: if true;
    }

    match /proyectos/{docId} {
      allow read, write: if isStaff();
    }

    match /documentos/{docId} {
      allow read, write: if isComercialUp();
    }

    match /movimientos/{docId} {
      allow read, write: if isAdmin();
    }

    match /cuentasBancarias/{docId} {
      allow read, write: if isAdmin();
    }

    match /logs/{docId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /employees/{docId} {
      allow read, write: if isAdmin();
    }

    match /payroll/{docId} {
      allow read, write: if isAdmin();
    }

    match /projects/{docId} {
      allow read: if isAdmin() || isAuthenticated();
      allow write: if isAdmin();
    }

    match /clients/{docId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }
  }
}
